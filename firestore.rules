rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow get: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    // SHARED VALIDATION HELPERS
    function validateTimestamp(data, field, isCreate) {
      return data[field] == (isCreate ? request.time : existing()[field]);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      // Reset Sessions
      match /reset_sessions/{sessionId} {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && incoming().code is string && incoming().code.size() == 6
          && incoming().expiry is number
          && incoming().email == request.auth.token.email;
        allow delete: if isOwner(userId);
      }

      // Settings
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(settingId);
      }

      // Products
      match /products/{productId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidProduct(incoming())
          && (
            // Action: Stock Update (most common)
            incoming().diff(existing()).affectedKeys().hasOnly(['stock']) ||
            // Action: Edit Product
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'code', 'price', 'stock', 'images'])
          );
        allow delete: if isOwner(userId);
      }

      function isValidProduct(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 200
          && data.code is string && data.code.size() <= 100
          && data.price is number && data.price >= 0
          && data.stock is number
          && (data.images is list || !data.keys().hasAny(['images']));
      }

      // Customers
      match /customers/{customerId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCustomer(incoming());
        allow update: if isOwner(userId) && isValidCustomer(incoming());
        allow delete: if isOwner(userId);
      }

      function isValidCustomer(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 100
          && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 20))
          && (!data.keys().hasAny(['address']) || (data.address is string && data.address.size() <= 500));
      }

      // Orders
      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOrder(incoming())
          && existsAfter(/databases/$(database)/documents/users/$(userId)/customers/$(incoming().customerId));
        allow update: if isOwner(userId) && isValidOrder(incoming())
          && (
            // Action: Payment Update
            incoming().diff(existing()).affectedKeys().hasOnly(['paidAmount', 'status', 'updatedAt'])
          );
        allow delete: if isOwner(userId);

        match /items/{itemId} {
          allow read: if isOwner(userId);
          allow write: if isOwner(userId);
        }
      }

      function isValidOrder(data) {
        return data.customerId is string && isValidId(data.customerId)
          && data.totalAmount is number && data.totalAmount >= 0
          && data.paidAmount is number && data.paidAmount >= 0
          && data.status in ['Paid', 'Due', 'Quotation']
          && (data.type in ['Invoice', 'Quotation', 'Purchase', 'Opening Balance', 'Entry']);
      }

      // Payments
      match /payments/{paymentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPayment(incoming())
          && existsAfter(/databases/$(database)/documents/users/$(userId)/customers/$(incoming().customerId));
        allow delete: if isOwner(userId);
      }

      function isValidPayment(data) {
        return data.customerId is string && isValidId(data.customerId)
          && data.amount is number && data.amount >= 0
          && data.paymentDate is string;
      }
    }
  }
}
