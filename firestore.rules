rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow get: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    // SHARED VALIDATION HELPERS
    function validateTimestamp(data, field, isCreate) {
      return data[field] == (isCreate ? request.time : existing()[field]);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      // Reset Sessions
      match /reset_sessions/{sessionId} {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) 
          && incoming().code is string && incoming().code.size() == 6
          && incoming().expiry is number
          && incoming().email == request.auth.token.email;
        allow delete: if isOwner(userId);
      }

      // Settings
      match /settings/{settingId} {
        allow read, list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(settingId);
      }

      // Products
      match /products/{productId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidProduct(incoming())
          && (
            // Action: Stock Update (most common)
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) ||
            // Action: Edit Product
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'code', 'price', 'stock', 'images', 'buyPrice', 'salePrice', 'stockAlert'])
          );
        allow delete: if isOwner(userId);
      }

      function isValidProduct(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 200
          && (!data.keys().hasAny(['code']) || (data.code is string && data.code.size() <= 100))
          && data.price is number && data.price >= 0
          && data.stock is number
          && (!data.keys().hasAny(['buyPrice']) || data.buyPrice is number)
          && (!data.keys().hasAny(['salePrice']) || data.salePrice is number)
          && (!data.keys().hasAny(['stockAlert']) || data.stockAlert is number)
          && (data.images is list || !data.keys().hasAny(['images']));
      }

      // Customers
      match /customers/{customerId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCustomer(incoming());
        allow update: if isOwner(userId) && isValidCustomer(incoming());
        allow delete: if isOwner(userId);
      }

      function isValidCustomer(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 100
          && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 64))
          && (!data.keys().hasAny(['address']) || (data.address is string && data.address.size() <= 2000));
      }

      // Orders
      match /orders/{orderId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOrder(incoming());
        allow update: if isOwner(userId) && isValidOrder(incoming())
          && (
            // Action: Payment Update or Status Update
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['paidAmount', 'status', 'updatedAt', 'totalDiscount'])
          );
        allow delete: if isOwner(userId);

        match /items/{itemId} {
          allow read, list: if isOwner(userId);
          allow write: if isOwner(userId) && isValidOrderItem(incoming());
        }
      }

      function isValidOrder(data) {
        return data.customerId is string && isValidId(data.customerId)
          && data.totalAmount is number && data.totalAmount >= 0
          && data.paidAmount is number && data.paidAmount >= 0
          && (!data.keys().hasAny(['totalDiscount']) || data.totalDiscount is number)
          && data.status in ['Paid', 'Due', 'Quotation']
          && (data.type in ['Invoice', 'Quotation', 'Purchase', 'Opening Balance', 'Entry']);
      }

      function isValidOrderItem(data) {
        return data.productId is string && (data.productId == '' || isValidId(data.productId))
          && data.quantity is number && data.quantity >= 0
          && data.price is number && data.price >= 0
          && (!data.keys().hasAny(['discount']) || data.discount is number)
          && (!data.keys().hasAny(['productName']) || data.productName is string);
      }

      // Payments
      match /payments/{paymentId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPayment(incoming());
        allow delete: if isOwner(userId);
      }

      function isValidPayment(data) {
        return data.customerId is string && isValidId(data.customerId)
          && data.amount is number && data.amount >= 0
          && data.paymentDate is string;
      }

      // Suppliers
      match /suppliers/{supplierId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSupplier(incoming());
        allow update: if isOwner(userId) && isValidSupplier(incoming());
        allow delete: if isOwner(userId);
      }

      function isValidSupplier(data) {
        return data.name is string && data.name.size() >= 1 && data.name.size() <= 100
          && data.phone is string && data.phone.size() <= 64
          && data.shopName is string && data.shopName.size() <= 200
          && (!data.keys().hasAny(['shopAddress']) || (data.shopAddress is string && data.shopAddress.size() <= 2000))
          && (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 256));
      }

      // Purchases
      match /purchases/{purchaseId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPurchase(incoming());
        allow update: if isOwner(userId) && isValidPurchase(incoming())
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['paidAmount', 'status', 'updatedAt', 'note'])
          );
        allow delete: if isOwner(userId);

        match /items/{itemId} {
          allow read, list: if isOwner(userId);
          allow write: if isOwner(userId) && isValidOrderItem(incoming());
        }
      }

      function isValidPurchase(data) {
        return data.supplierId is string && isValidId(data.supplierId)
          && data.totalAmount is number && data.totalAmount >= 0
          && data.paidAmount is number && data.paidAmount >= 0
          && data.status in ['Paid', 'Due']
          && (!data.keys().hasAny(['note']) || data.note is string);
      }
    }
  }
}
